<mah:MetroWindow x:Class="Perelegans.Views.BatchMetadataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate BatchMeta_Title}"
        TitleCharacterCasing="Normal"
        Height="720" Width="1200"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}"
        mah:DialogParticipation.Register="{Binding}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </mah:MetroWindow.Resources>

    <Grid Margin="12,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Game list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter bar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Margin="8,0,0,0">
                        <Run Text="Total: "/>
                        <Run Text="{Binding Entries.Count}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
                <TextBox Height="28" FontSize="12" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="{i18n:Translate BatchMeta_FilterWatermark}"
                         mah:TextBoxHelper.ClearTextButton="True">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="mah:TextBoxHelper.ButtonContent">
                                <Setter.Value>
                                    <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>

            <!-- Games DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding EntriesView}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="26"
                      FontSize="12"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                      Background="Transparent">
                <DataGrid.Columns>
                    <!-- Completeness indicator -->
                    <DataGridTemplateColumn Header="{i18n:Translate BatchMeta_ColComplete}" Width="70" CanUserSort="True" SortMemberPath="CompletenessScore">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding CompletenessScore, StringFormat='{}{0}%'}">
                                    <ProgressBar Value="{Binding CompletenessScore}" Maximum="100" Height="14" BorderThickness="0"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Title -->
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColTitle}" Binding="{Binding Title}" Width="2*" MinWidth="120"/>

                    <!-- Brand -->
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColBrand}" Binding="{Binding Brand}" Width="120"/>

                    <!-- Release Date -->
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColDate}"
                                        Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}"
                                        Width="90"/>

                    <!-- Status -->
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColStatus}"
                                        Binding="{Binding StatusText}" Width="80"/>

                    <!-- Completeness -->
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColComplete}"
                                        Binding="{Binding CompletenessScore, StringFormat={}{0}%}"
                                        Width="65"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- RIGHT: Detail / Search panel -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,6" IsEnabled="{Binding SelectedEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button DockPanel.Dock="Right" Height="28" Width="70" FontSize="12" Margin="4,0,0,0"
                        Content="{i18n:Translate BatchMeta_SearchBtn}"
                        Command="{Binding SearchAllCommand}"/>
                <TextBox Height="28" FontSize="12"
                         Text="{Binding SelectedEntry.Title, Mode=OneWay}"
                         IsReadOnly="True"
                         mah:TextBoxHelper.Watermark="Select a game..."/>
            </DockPanel>

            <!-- Search results -->
            <DataGrid Grid.Row="1" MaxHeight="200"
                      ItemsSource="{Binding SearchResults}"
                      SelectedItem="{Binding SelectedResult}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="24"
                      FontSize="11"
                      Visibility="{Binding SearchResults.Count, Converter={StaticResource BooleanToVisibilityConverter}}"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource Perelegans.BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="85"/>
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColTitle}" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColBrand}" Binding="{Binding Brand}" Width="80"/>
                    <DataGridTextColumn Header="{i18n:Translate BatchMeta_ColDate}"
                                        Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Search progress + Apply -->
            <DockPanel Grid.Row="2" Margin="0,4,0,4">
                <Button DockPanel.Dock="Right" Height="26" FontSize="12"
                        Content="{i18n:Translate BatchMeta_ApplyBtn}"
                        Command="{Binding ApplySelectedResultCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <TextBlock Text="{Binding SearchProgress}" FontSize="11"
                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                           VerticalAlignment="Center" Margin="4,0"/>
            </DockPanel>

            <!-- Editable fields -->
            <ScrollViewer Grid.Row="3" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="85"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{i18n:Translate BatchMeta_Editing}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,6,0,8"
                               Foreground="{DynamicResource Perelegans.AccentBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{i18n:Translate Meta_FieldTitle}" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                             Text="{Binding SelectedEntry.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{i18n:Translate Meta_FieldBrand}" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                             Text="{Binding SelectedEntry.Brand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{i18n:Translate Meta_FieldDate}" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <DatePicker Grid.Row="3" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                                SelectedDate="{Binding SelectedEntry.ReleaseDate, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="VNDB ID:" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                             Text="{Binding SelectedEntry.VndbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="v12345"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Bangumi ID:" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                             Text="{Binding SelectedEntry.BangumiId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="EGS ID:" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                             Text="{Binding SelectedEntry.EgsId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{i18n:Translate Meta_FieldWebsite}" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Height="26" FontSize="12" Margin="2"
                             Text="{Binding SelectedEntry.Website, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="https://..."/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="{i18n:Translate Meta_FieldTags}" FontSize="12" VerticalAlignment="Center" Margin="0,2"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Height="88" FontSize="12" Margin="2"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Text="{Binding SelectedEntry.TagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{i18n:Translate Meta_TagsWatermark}"/>
                </Grid>
            </ScrollViewer>

            <!-- Search progress indicator -->
            <TextBlock Grid.Row="9" Text="{Binding SearchProgress}" FontSize="11"
                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                       Margin="0,2" Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Save / Close buttons -->
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Height="30" Width="100" FontSize="12" Margin="0,0,8,0"
                        Content="{i18n:Translate BatchMeta_SaveAll}"
                        Command="{Binding SaveAllCommand}"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <Button Height="30" Width="80" FontSize="12"
                        Content="{i18n:Translate Btn_Cancel}"
                        Click="BtnCancel_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
