<mah:MetroWindow x:Class="Perelegans.Views.GameManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:Perelegans.Converters"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="Game Management"
        TitleCharacterCasing="Normal"
        Height="600" Width="900"
        MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}"
        mah:DialogParticipation.Register="{Binding}">

    <mah:MetroWindow.Resources>
        <converters:PlaytimeConverter x:Key="PlaytimeConverter"/>
        <converters:StatusIconConverter x:Key="StatusIconConverter"/>

        <Style x:Key="SelectedPrimaryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalCount}" FontWeight="SemiBold"/>
                    <Run Text=" / Selected: "/>
                    <Run Text="{Binding SelectedCount}" FontWeight="SemiBold" Foreground="#E37F7F"/>
                </TextBlock>
            </StackPanel>
            <TextBox Height="28" FontSize="12" VerticalContentAlignment="Center"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     mah:TextBoxHelper.Watermark="Filter by title..."
                     mah:TextBoxHelper.ClearTextButton="True">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="mah:TextBoxHelper.ButtonContent">
                            <Setter.Value>
                                <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </DockPanel>

        <!-- Selection Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Height="26" FontSize="12" Margin="0,0,6,0"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Content="Select All"
                    Command="{Binding SelectAllCommand}"/>
            <Button Height="26" FontSize="12" Margin="0,0,6,0"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Content="Deselect All"
                    Command="{Binding DeselectAllCommand}"/>
            <Button Height="26" FontSize="12" Margin="0,0,6,0"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Content="Invert Selection"
                    Command="{Binding InvertSelectionCommand}"/>
        </StackPanel>

        <!-- DataGrid with checkbox column -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding GamesView}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  FontSize="12"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                  Background="Transparent"
                  RowHeight="24"
                  ColumnHeaderHeight="26"
                  SelectionUnit="CellOrRowHeader">
            <DataGrid.Columns>
                <!-- Checkbox -->
                <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status -->
                <DataGridTemplateColumn Header="" Width="32" CanUserResize="False" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <iconPacks:PackIconMaterial
                                Kind="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                Width="14" Height="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Perelegans.StatusIconBrush}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Title -->
                <DataGridTextColumn Header="{i18n:Translate Column_Title}" Binding="{Binding Title}"
                                     Width="2*" MinWidth="120"
                                     ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                <!-- Brand -->
                <DataGridTextColumn Header="{i18n:Translate Column_Brand}" Binding="{Binding Brand}"
                                     Width="120"
                                     ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                <!-- Release Date -->
                <DataGridTextColumn Header="{i18n:Translate Column_ReleaseDate}"
                                     Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}"
                                     Width="95"
                                     ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                <!-- Playtime -->
                <DataGridTextColumn Header="{i18n:Translate Column_Playtime}"
                                     Binding="{Binding Playtime, Converter={StaticResource PlaytimeConverter}}"
                                     Width="75"
                                     ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                <!-- Created Date -->
                <DataGridTextColumn Header="{i18n:Translate Column_Created}"
                                     Binding="{Binding CreatedDate, StringFormat=yyyy-MM-dd}"
                                     Width="85"
                                     Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>

                <!-- Accessed Date -->
                <DataGridTextColumn Header="{i18n:Translate Column_LastPlayed}"
                                     Binding="{Binding AccessedDate, StringFormat=yyyy-MM-dd}"
                                     Width="85"
                                     Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Height="30" FontSize="12" Margin="0,0,8,0"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Command="{Binding DeleteSelectedCommand}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                Foreground="#E53935" Margin="0,0,4,0"/>
                    <TextBlock Text="Delete Selected" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Height="30" FontSize="12" Width="80"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Content="{i18n:Translate Btn_Cancel}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
