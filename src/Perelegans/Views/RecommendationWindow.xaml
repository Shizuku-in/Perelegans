<mah:MetroWindow x:Class="Perelegans.Views.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate Rec_Title}"
        TitleCharacterCasing="Normal"
        Height="760" Width="1220"
        MinHeight="620" MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}"
        mah:DialogParticipation.Register="{Binding}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </mah:MetroWindow.Resources>

    <Grid Margin="12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                <TextBlock Text="{Binding ProfileSummaryText}" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TopTagsText}" Margin="0,3,0,0" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                <TextBlock Text="{Binding AvoidTagsText}" Margin="0,2,0,0" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                <TextBlock Text="{Binding PreferredDevelopersText}" Margin="0,2,0,0" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                <TextBlock Text="{Binding ProfileDepthText}" Margin="0,2,0,0" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                <TextBlock Text="{Binding AiStatusText}" Margin="0,6,0,0" Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                <TextBlock Text="{Binding AiProfileText}" Margin="0,2,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="860"
                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Margin="12,0,0,0"
                        VerticalAlignment="Top">
                <TextBlock Text="{i18n:Translate Rec_ModeLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <ComboBox Width="132"
                          Height="30"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding ModeOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedMode, Mode=TwoWay}"/>
                <Button Width="108" Height="30"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Content="{i18n:Translate Rec_Refresh}"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding WorkflowSteps}" Margin="0,0,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,0"
                                Padding="10,6"
                                Background="{DynamicResource Perelegans.PanelBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding StatusText}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.AccentBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Text="{Binding EmptyStateText}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Recommendations}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeight="132"
                  ColumnHeaderHeight="28"
                  FontSize="12"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                  Background="Transparent"
                  Visibility="{Binding HasRecommendations, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{i18n:Translate Rec_ColTitle}" Binding="{Binding DisplayTitleWithChineseTranslation}" Width="1.6*"/>
                <DataGridTextColumn Header="{i18n:Translate Rec_ColBrand}" Binding="{Binding Brand}" Width="1.2*"/>
                <DataGridTextColumn Header="{i18n:Translate Rec_ColDate}" Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                <DataGridTextColumn Header="{i18n:Translate Rec_ColScore}" Binding="{Binding RecommendationScore, StringFormat=F2}" Width="90"/>
                <DataGridTemplateColumn Header="{i18n:Translate Rec_ColBreakdown}" Width="1.4*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,6">
                                <TextBlock Text="{Binding ScoreBreakdown}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SellingPoint}" Margin="0,6,0,0"
                                           Foreground="{DynamicResource Perelegans.AccentBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{i18n:Translate Rec_ColReason}" Width="2.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <TextBlock Text="{Binding Reason}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SourceMatchSummary, StringFormat={}{0}}"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Caution}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{i18n:Translate Rec_ColActions}" Width="182" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center">
                                <UniformGrid Columns="2" Margin="0,4,0,0">
                                    <Button Height="28"
                                            Margin="0,0,4,0"
                                            BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                                            IsEnabled="{Binding CanLike}"
                                            Content="{Binding LikeButtonText}"
                                            Command="{Binding DataContext.LikeRecommendationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Height="28"
                                            Margin="4,0,0,0"
                                            BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                                            IsEnabled="{Binding CanDislike}"
                                            Content="{Binding DislikeButtonText}"
                                            Command="{Binding DataContext.DislikeRecommendationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </UniformGrid>
                                <Button Height="28"
                                        Margin="0,6,0,0"
                                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                                        IsEnabled="{Binding CanImport}"
                                        Content="{Binding ImportButtonText}"
                                        Command="{Binding DataContext.ImportRecommendationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <UniformGrid Columns="2" Margin="0,6,0,0">
                                    <Button Height="28"
                                            Margin="0,0,4,0"
                                            BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                                            Content="{i18n:Translate Rec_OpenVndb}"
                                            Command="{Binding DataContext.OpenVndbCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Height="28"
                                            Margin="4,0,0,0"
                                            BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                                            IsEnabled="{Binding HasBangumiUrl}"
                                            Content="{i18n:Translate Rec_OpenBangumi}"
                                            Command="{Binding DataContext.OpenBangumiCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </UniformGrid>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</mah:MetroWindow>
