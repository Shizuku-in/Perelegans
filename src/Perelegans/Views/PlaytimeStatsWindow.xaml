<mah:MetroWindow x:Class="Perelegans.Views.PlaytimeStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate Stats_Title}"
        TitleCharacterCasing="Normal"
        Height="520" Width="720"
        WindowStartupLocation="CenterOwner"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <Style x:Key="StatsSelectedTextCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Selector -->
        <TabControl Grid.Row="0" Height="30"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    FontSize="12" Padding="0">
            <TabItem Header="{i18n:Translate Stats_Tab7Days}"/>
            <TabItem Header="{i18n:Translate Stats_TabWeekly}"/>
            <TabItem Header="{i18n:Translate Stats_TabMonthly}"/>
            <TabItem Header="{i18n:Translate Stats_TabYearly}"/>
        </TabControl>

        <!-- Content: Table + Chart -->
        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Period Data Table -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding PeriodData}"
                      SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                      CellStyle="{StaticResource StatsSelectedTextCellStyle}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="22"
                      ColumnHeaderHeight="24"
                      FontSize="11"
                      BorderThickness="1"
                      Margin="0,0,6,0"
                      BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                      Background="Transparent"
                      RowBackground="{DynamicResource Perelegans.WindowBackground}"
                      AlternatingRowBackground="{DynamicResource Perelegans.DataGridAltRowBrush}"
                      HorizontalGridLinesBrush="{DynamicResource Perelegans.BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{i18n:Translate Stats_ColPeriod}" Binding="{Binding Label}" Width="*"/>
                    <DataGridTextColumn Header="{i18n:Translate Stats_ColPlaytime}" Binding="{Binding PlaytimeText}" Width="70"/>
                    <DataGridTextColumn Header="{i18n:Translate Stats_ColSessions}" Binding="{Binding SessionCount}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Pink Pie Chart -->
            <lvc:PieChart Grid.Column="1"
                          Series="{Binding PieSeries}"
                          LegendPosition="Bottom"
                          LegendTextSize="11"
                          InitialRotation="-90"/>
        </Grid>
    </Grid>
</mah:MetroWindow>
