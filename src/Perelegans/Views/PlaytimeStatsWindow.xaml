<mah:MetroWindow x:Class="Perelegans.Views.PlaytimeStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate Stats_Title}"
        TitleCharacterCasing="Normal"
        Height="540" Width="720"
        WindowStartupLocation="CenterOwner"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <Style x:Key="StatsTabItemStyle"
               TargetType="TabItem"
               BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatsSelectedTextCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Selector -->
        <TabControl Grid.Row="0"
                    Height="44"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    FontSize="17"
                    Padding="0"
                    ItemContainerStyle="{StaticResource StatsTabItemStyle}">
            <TabItem Header="{i18n:Translate Stats_Tab7Days}"/>
            <TabItem Header="{i18n:Translate Stats_TabWeekly}"/>
            <TabItem Header="{i18n:Translate Stats_TabMonthly}"/>
            <TabItem Header="{i18n:Translate Stats_TabYearly}"/>
        </TabControl>

        <!-- Content: Table + Chart -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Period Data Table -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding PeriodData}"
                      SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                      CellStyle="{StaticResource StatsSelectedTextCellStyle}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="22"
                      ColumnHeaderHeight="24"
                      FontSize="11"
                      BorderThickness="1"
                      Margin="0,0,6,0"
                      BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                      Background="Transparent"
                      RowBackground="{DynamicResource Perelegans.WindowBackground}"
                      AlternatingRowBackground="{DynamicResource Perelegans.DataGridAltRowBrush}"
                      HorizontalGridLinesBrush="{DynamicResource Perelegans.BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{i18n:Translate Stats_ColPeriod}" Binding="{Binding Label}" Width="*"/>
                    <DataGridTextColumn Header="{i18n:Translate Stats_ColPlaytime}" Binding="{Binding PlaytimeText}" Width="70"/>
                    <DataGridTextColumn Header="{i18n:Translate Stats_ColSessions}" Binding="{Binding SessionCount}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Chart panel -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Perelegans.StatsChartPanelBackground}"
                    BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="14,12,14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{i18n:Translate Stats_Title}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                        <TextBlock Text="{Binding ChartSubtitle}"
                                   Margin="0,2,0,0"
                                   FontSize="10"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,12,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                CornerRadius="0"
                                Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{i18n:Translate Stats_ColPlaytime}"
                                           FontSize="10"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                <TextBlock Text="{Binding SelectedPeriod.PlaytimeText, TargetNullValue=-}"
                                           Margin="0,2,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                CornerRadius="0"
                                Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{i18n:Translate Stats_ColSessions}"
                                           FontSize="10"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                <TextBlock Text="{Binding SelectedPeriod.SessionCount, TargetNullValue=-}"
                                           Margin="0,2,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Width="208"
                            Height="208"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,0,0,10">
                        <lvc:PieChart x:Name="PieStatsChart"
                                      Series="{Binding PieSeries}"
                                      LegendPosition="Hidden"
                                      TooltipPosition="Hidden"
                                      HoveredPointsChangedCommand="{Binding PieHoverChangedCommand}"
                                      InitialRotation="-90"
                                      Background="Transparent"
                                      MouseLeave="PieStatsChart_MouseLeave"/>
                    </Border>

                    <ScrollViewer x:Name="LegendScrollViewer"
                                  Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="LegendItemsControl"
                                      ItemsSource="{Binding PieLegendItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="LegendItemBorder"
                                            Margin="0,0,0,8"
                                            Padding="6,5"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="10"
                                                    Height="10"
                                                    CornerRadius="0"
                                                    Background="{Binding SwatchBrush}"
                                                    VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                                <TextBlock x:Name="LegendTitleText"
                                                           Text="{Binding Title}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding PlaytimeText}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                            </StackPanel>

                                            <TextBlock x:Name="LegendPercentageText"
                                                       Grid.Column="2"
                                                       Text="{Binding PercentageText}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                            <Setter TargetName="LegendItemBorder" Property="Background" Value="{DynamicResource Perelegans.StatsChartHighlightBackground}"/>
                                            <Setter TargetName="LegendItemBorder" Property="BorderBrush" Value="{DynamicResource Perelegans.StatsChartHighlightBorderBrush}"/>
                                            <Setter TargetName="LegendTitleText" Property="FontWeight" Value="SemiBold"/>
                                            <Setter TargetName="LegendPercentageText" Property="Foreground" Value="{DynamicResource Perelegans.StatsChartHighlightBorderBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
