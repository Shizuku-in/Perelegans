<mah:MetroWindow x:Class="Perelegans.Views.AddFromProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="从进程添加 (Add From Process)"
        Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新列表" Width="80" Height="26" FontSize="11"
                    Command="{Binding RefreshProcessesCommand}"/>
            <TextBlock Text="仅显示具有主窗口标题的进程" Margin="10,0,0,0" VerticalAlignment="Center" 
                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}" FontSize="11"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Processes}"
                  SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeight="22"
                  ColumnHeaderHeight="24"
                  FontSize="11"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                  Background="Transparent"
                  RowBackground="{DynamicResource Perelegans.WindowBackground}"
                  AlternatingRowBackground="{DynamicResource Perelegans.DataGridAltRowBrush}"
                  HorizontalGridLinesBrush="{DynamicResource Perelegans.BorderBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Window Title" Binding="{Binding WindowTitle}" Width="150"/>
                <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="100"/>
                <DataGridTextColumn Header="Path" Binding="{Binding ExecutablePath}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Width="80" Height="28" FontSize="12" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="BtnOk_Click"/>
            <Button Content="取消" Width="80" Height="28" FontSize="12"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
