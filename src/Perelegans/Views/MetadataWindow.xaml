<mah:MetroWindow x:Class="Perelegans.Views.MetadataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:converters="clr-namespace:Perelegans.Converters"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate Meta_Title}"
        TitleCharacterCasing="Normal"
        Height="680" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:CoverArtImageSourceConverter x:Key="CoverArtImageSourceConverter"/>
        <Style x:Key="MetadataSelectedTextCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,6" Visibility="{Binding IsSearchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" Height="26" FontSize="12"
                     VerticalContentAlignment="Center" Margin="0,0,4,0"
                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     mah:TextBoxHelper.Watermark="{i18n:Translate Meta_SearchWatermark}"
                     KeyDown="SearchBox_KeyDown"/>

            <ComboBox Grid.Column="1" Height="26" FontSize="12" Margin="0,0,4,0"
                      ItemsSource="{Binding SourceOptions}"
                      SelectedItem="{Binding SelectedSource, Mode=TwoWay}"/>

            <Button Grid.Column="2" Width="60" Height="26" FontSize="11"
                    Content="{i18n:Translate Meta_SearchBtn}"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Command="{Binding SearchCommand}"/>
        </Grid>

        <DataGrid Grid.Row="1"
                  Visibility="{Binding IsSearchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                  ItemsSource="{Binding SearchResults}"
                  SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                  CellStyle="{StaticResource MetadataSelectedTextCellStyle}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeight="22"
                  ColumnHeaderHeight="24"
                  FontSize="11"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                  Background="Transparent"
                  RowBackground="{DynamicResource Perelegans.WindowBackground}"
                  AlternatingRowBackground="{DynamicResource Perelegans.DataGridAltRowBrush}"
                  HorizontalGridLinesBrush="{DynamicResource Perelegans.BorderBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{i18n:Translate Meta_ColSource}" Binding="{Binding Source}" Width="70"/>
                <DataGridTextColumn Header="{i18n:Translate Meta_ColTitle}" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="{i18n:Translate Meta_ColBrand}" Binding="{Binding Brand}" Width="100"/>
                <DataGridTextColumn Header="{i18n:Translate Meta_ColDate}" Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,4"
                    Visibility="{Binding IsSearchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button Content="{i18n:Translate Meta_ApplyBtn}" Width="80" Height="26" FontSize="11"
                    Padding="8,1"
                    VerticalContentAlignment="Center"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Command="{Binding ApplySelectedCommand}"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
            <TextBlock Text="{i18n:Translate Meta_ApplyHint}" FontSize="10" VerticalAlignment="Center"
                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}" Margin="8,0,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="3" Grid.RowSpan="12"
                        Padding="10"
                        Background="{DynamicResource Perelegans.PanelBackground}"
                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Meta_SourceStatusTitle}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Text="VNDB" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VndbSourceStatusText}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                            <TextBlock Grid.Row="2" Text="Bangumi" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BangumiSourceStatusText}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                            <TextBlock Grid.Row="4" Text="ErogameSpace" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EgsSourceStatusText}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        </Grid>

                        <Border Padding="8,6"
                                Background="{DynamicResource Perelegans.WindowBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <TextBlock Text="{Binding MetadataStatusText}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Perelegans.AccentBrush}"
                                       FontSize="11"/>
                        </Border>

                        <TextBlock Text="{i18n:Translate Meta_CoverStatusTitle}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding CoverStatusText}"
                                   TextWrapping="Wrap"
                                   MinHeight="46"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="0" Text="{i18n:Translate Meta_FieldTitle}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="0" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditTitle, Mode=TwoWay}"/>

                <TextBlock Grid.Row="1" Text="{i18n:Translate Meta_FieldBrand}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="1" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditBrand, Mode=TwoWay}"/>

                <TextBlock Grid.Row="2" Text="{i18n:Translate Meta_FieldDate}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <DatePicker Grid.Row="2" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                            SelectedDate="{Binding EditReleaseDate, Mode=TwoWay}"/>

                <TextBlock Grid.Row="3" Text="{i18n:Translate Meta_FieldStatus}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <ComboBox Grid.Row="3" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                          ItemsSource="{Binding StatusOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding EditStatus, Mode=TwoWay}"/>

                <TextBlock Grid.Row="4" Text="VNDB ID:" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="4" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditVndbId, Mode=TwoWay}"
                         mah:TextBoxHelper.Watermark="v12345"/>

                <TextBlock Grid.Row="5" Text="Bangumi ID:" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="5" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditBangumiId, Mode=TwoWay}"/>

                <TextBlock Grid.Row="6" Text="EGS ID:" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="6" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditEgsId, Mode=TwoWay}"/>

                <TextBlock Grid.Row="7" Text="{i18n:Translate Meta_FieldWebsite}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="7" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditWebsite, Mode=TwoWay}"
                         mah:TextBoxHelper.Watermark="https://..."/>

                <TextBlock Grid.Row="8" Text="{i18n:Translate Meta_FieldCover}" VerticalAlignment="Top" FontSize="12" Margin="0,6,0,2"/>
                <Grid Grid.Row="8" Grid.Column="1" Margin="0,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Height="190"
                            Margin="0,0,0,8"
                            Background="{DynamicResource Perelegans.PanelBackground}"
                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Image Source="{Binding CoverPreviewSource, Converter={StaticResource CoverArtImageSourceConverter}}"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{i18n:Translate Meta_CoverPreviewEmpty}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoverPreviewSource}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,2">
                        <Button Height="28" FontSize="11" Margin="0,0,8,0"
                                Padding="8,0"
                                BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                                Content="{i18n:Translate Meta_CoverFetchBtn}"
                                Click="AutoFetchCover_Click"/>
                        <Button Height="28" FontSize="11" Margin="0,0,8,0"
                                Padding="8,0"
                                BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                Style="{DynamicResource MahApps.Styles.Button.Square}"
                                Content="{i18n:Translate Meta_CoverImportLocalBtn}"
                                Command="{Binding ImportFromLocalCommand}"/>
                        <Button Height="28" FontSize="11"
                                Padding="8,0"
                                BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                                Style="{DynamicResource MahApps.Styles.Button.Square}"
                                Content="{i18n:Translate Meta_CoverClearBtn}"
                                Command="{Binding ClearCoverCommand}"/>
                    </UniformGrid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding CoverStatusText}"
                               FontSize="10.5"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </Grid>

                <TextBlock Grid.Row="9" Text="{i18n:Translate Meta_FieldTags}" VerticalAlignment="Top" FontSize="12" Margin="0,6,0,2"/>
                <TextBox Grid.Row="9" Grid.Column="1" Height="88" MaxHeight="88" FontSize="12" Margin="0,2"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding EditTagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="{i18n:Translate Meta_TagsWatermark}"/>

                <TextBlock Grid.Row="10" Text="{i18n:Translate Meta_FieldProcess}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <TextBox Grid.Row="10" Grid.Column="1" Height="24" FontSize="12" Margin="0,2"
                         VerticalContentAlignment="Center"
                         Text="{Binding EditProcessName, Mode=TwoWay}"
                         mah:TextBoxHelper.Watermark="GAME_PROCESS.exe"/>

                <TextBlock Grid.Row="11" Text="{i18n:Translate Meta_FieldExec}" VerticalAlignment="Center" FontSize="12" Margin="0,2"/>
                <Grid Grid.Row="11" Grid.Column="1" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Height="24" FontSize="12" Margin="0,0,4,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding EditExecutablePath, Mode=TwoWay}"
                             mah:TextBoxHelper.Watermark="C:\Games\Game.exe"/>
                    <Button Grid.Column="1" Content="..." Width="30" Height="24"
                            BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                            Command="{Binding BrowseExecutableCommand}"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="{i18n:Translate Btn_Save}" Width="80" Height="28" FontSize="12"
                    Margin="0,0,8,0"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="BtnSave_Click"/>
            <Button Content="{i18n:Translate Btn_Cancel}" Width="80" Height="28" FontSize="12"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
