<mah:MetroWindow x:Class="Perelegans.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:models="clr-namespace:Perelegans.Models"
        Title="Settings"
        TitleCharacterCasing="Normal"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowTitleBar="True"
        TitleBarHeight="28"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}"
        xmlns:i18n="clr-namespace:Perelegans.i18n">

    <mah:MetroWindow.Resources>
        <ObjectDataProvider x:Key="ThemeModes" MethodName="GetValues" ObjectType="{x:Type models:ThemeMode}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ThemeMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </mah:MetroWindow.Resources>

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section 1: 外観 (Appearance / Language) -->
        <GroupBox Grid.Row="0" Header="{i18n:Translate Settings_Appearance}" Margin="0,0,0,8"
                  Padding="8,6" FontSize="12"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Text="{i18n:Translate Settings_ThemeMode}" VerticalAlignment="Center" FontSize="12"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Height="26" FontSize="12"
                          ItemsSource="{Binding Source={StaticResource ThemeModes}}"
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"/>

                <TextBlock Grid.Row="2" Text="{i18n:Translate Settings_Language}" VerticalAlignment="Center" FontSize="12"/>
                <ComboBox Grid.Row="2" Grid.Column="1" Height="26" FontSize="12"
                          ItemsSource="{Binding LanguageOptions}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"/>
            </Grid>
        </GroupBox>

        <!-- Section 2: 監視 (Monitor) -->
        <GroupBox Grid.Row="1" Header="{i18n:Translate Settings_Monitor}" Margin="0,0,0,8"
                  Padding="8,6" FontSize="12"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Text="{i18n:Translate Settings_Enabled}" VerticalAlignment="Center" FontSize="12"/>
                <CheckBox Grid.Row="0" Grid.Column="1"
                          IsChecked="{Binding MonitorEnabled, Mode=TwoWay}"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Text="{i18n:Translate Settings_Interval}" VerticalAlignment="Center" FontSize="12"/>
                <mah:NumericUpDown Grid.Row="2" Grid.Column="1"
                                   Value="{Binding MonitorIntervalSeconds, Mode=TwoWay}"
                                   Minimum="1" Maximum="60" Interval="1"
                                   Width="70"
                                   Height="26" FontSize="12"
                                   HorizontalAlignment="Left"
                                   NumericInputMode="Numbers"/>
            </Grid>
        </GroupBox>

        <!-- Section 3: 网络 (Network) -->
        <GroupBox Grid.Row="2" Header="{i18n:Translate Settings_Network}" Margin="0,0,0,8"
                  Padding="8,6" FontSize="12"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{i18n:Translate Settings_Proxy}" VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" Height="26" FontSize="12"
                         VerticalContentAlignment="Center"
                         Text="{Binding ProxyAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="http://127.0.0.1:7890"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="{i18n:Translate Settings_System}" Margin="0,0,0,8"
                  Padding="8,6" FontSize="12"
                  BorderBrush="{DynamicResource Perelegans.BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Text="{i18n:Translate Settings_LaunchAtStartup}" VerticalAlignment="Center" FontSize="12"/>
                <CheckBox Grid.Row="0" Grid.Column="1"
                          IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Text="{i18n:Translate Settings_CloseBehavior}" VerticalAlignment="Center" FontSize="12"/>
                <ComboBox Grid.Row="2" Grid.Column="1" Height="26" FontSize="12"
                          ItemsSource="{Binding CloseBehaviorOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedCloseBehavior, Mode=TwoWay}"/>
            </Grid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="{i18n:Translate Btn_Save}" Width="80" Height="28" FontSize="12"
                    Margin="0,0,8,0"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="BtnSave_Click"/>
            <Button Content="{i18n:Translate Btn_Cancel}" Width="80" Height="28" FontSize="12"
                    BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
