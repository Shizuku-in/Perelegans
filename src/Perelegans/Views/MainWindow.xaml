<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:Perelegans.Converters"
        xmlns:models="clr-namespace:Perelegans.Models"
        mc:Ignorable="d"
        Title="Perelegans"
        TitleCharacterCasing="Normal"
        Height="680" Width="1100"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        ShowTitleBar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Perelegans.WindowBackground}">

    <mah:MetroWindow.Resources>
        <converters:PlaytimeConverter x:Key="PlaytimeConverter"/>
        <converters:StatusIconConverter x:Key="StatusIconConverter"/>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- ==================== 1. CUSTOM TITLE BAR ==================== -->
        <Grid DockPanel.Dock="Top" Height="30"
              Background="{DynamicResource Perelegans.PanelBackground}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <iconPacks:PackIconMaterial Kind="GamepadVariantOutline"
                                            Width="14" Height="14"
                                            Foreground="{DynamicResource Perelegans.AccentBrush}"
                                            VerticalAlignment="Center"/>
                <TextBlock Text="Perelegans" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                           Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: Settings / Min / Max / Close buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Stretch">
                <!-- Settings -->
                <Button x:Name="BtnSettings" Click="BtnSettings_Click"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Settings">
                    <iconPacks:PackIconMaterial Kind="CogOutline" Width="12" Height="12"/>
                </Button>
                <!-- Minimize -->
                <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Minimize">
                    <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="12" Height="12"/>
                </Button>
                <!-- Maximize / Restore -->
                <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Maximize">
                    <iconPacks:PackIconMaterial Kind="WindowMaximize" Width="12" Height="12"
                                                x:Name="MaximizeIcon"/>
                </Button>
                <!-- Close -->
                <Button x:Name="BtnClose" Click="BtnClose_Click"
                        Style="{DynamicResource Perelegans.CloseButtonStyle}"
                        ToolTip="Close">
                    <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== 2. MENU BAR ==================== -->
        <Menu DockPanel.Dock="Top" Height="24"
              Background="{DynamicResource Perelegans.PanelBackground}"
              Foreground="{DynamicResource Perelegans.ForegroundBrush}"
              FontSize="12" Padding="4,0">

            <!-- File -->
            <MenuItem Header="_File">
                <MenuItem Header="从进程添加 (_P)" Command="{Binding AddFromProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ApplicationCogOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="从网站添加 (_W)" Command="{Binding AddFromWebsiteCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Web" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="保存备份 (_S)" Command="{Binding SaveBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="恢复备份 (_R)" Command="{Binding RestoreBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Restore" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="退出 (_X)" Command="{Binding ExitAppCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Tool -->
            <MenuItem Header="_Tool">
                <MenuItem Header="监视进程 (_M)" Command="{Binding MonitorProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="MonitorEye" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="游玩时间统计 (_T)" Command="{Binding PlaytimeStatisticsCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="语言 (_L)">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Translate" Width="14" Height="14"/>
                    </MenuItem.Icon>
                    <MenuItem Header="日本語"/>
                    <MenuItem Header="简体中文"/>
                    <MenuItem Header="English"/>
                </MenuItem>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="_Help">
                <MenuItem Header="关于 (_A)" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ==================== 4. STATUS BAR ==================== -->
        <StatusBar DockPanel.Dock="Bottom" Height="22"
                   Background="{DynamicResource Perelegans.StatusBarBackground}"
                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                   FontSize="11" Padding="8,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Total Playtime: "/>
                        <Run Text="{Binding TotalPlaytimeText, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Completed: "/>
                        <Run Text="{Binding CompletedCount, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== 3. CLIENT AREA ==================== -->
        <Grid Background="{DynamicResource Perelegans.WindowBackground}">

            <!-- Background Tachie Image (lower z-index) -->
            <Image Source="{x:Null}"
                   Stretch="Uniform"
                   Opacity="0.12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   MaxHeight="500"
                   MaxWidth="350"
                   Margin="0,0,20,30"
                   Panel.ZIndex="0"
                   IsHitTestVisible="False"/>

            <!-- DataGrid (upper z-index) -->
            <DataGrid x:Name="GameDataGrid"
                      ItemsSource="{Binding Games}"
                      SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="24"
                      ColumnHeaderHeight="26"
                      FontSize="12"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="{DynamicResource Perelegans.WindowBackground}"
                      AlternatingRowBackground="{DynamicResource Perelegans.DataGridAltRowBrush}"
                      Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                      HorizontalGridLinesBrush="{DynamicResource Perelegans.BorderBrush}"
                      Panel.ZIndex="1"
                      Margin="0">

                <!-- Context Menu -->
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="启动" Command="{Binding StartGameCommand}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="元数据">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="DatabaseOutline" Width="14" Height="14"/>
                            </MenuItem.Icon>
                            <MenuItem Header="获取元数据" Command="{Binding FetchMetadataCommand}"/>
                            <MenuItem Header="编辑元数据" Command="{Binding EditMetadataCommand}"/>
                        </MenuItem>
                        <MenuItem Header="打开">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Width="14" Height="14"/>
                            </MenuItem.Icon>
                            <MenuItem Header="打开游戏文件夹" Command="{Binding OpenGameFolderCommand}"/>
                            <MenuItem Header="打开网页">
                                <MenuItem Header="VNDB" Command="{Binding OpenVndbCommand}"/>
                                <MenuItem Header="ErogameSpace" Command="{Binding OpenErogameSpaceCommand}"/>
                                <MenuItem Header="Bangumi" Command="{Binding OpenBangumiCommand}"/>
                                <MenuItem Header="官网" Command="{Binding OpenOfficialSiteCommand}"/>
                            </MenuItem>
                            <MenuItem Header="打开游戏时间统计" Command="{Binding OpenGamePlaytimeStatsCommand}"/>
                        </MenuItem>
                        <MenuItem Header="复制">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                            </MenuItem.Icon>
                            <MenuItem Header="复制标题" Command="{Binding CopyTitleCommand}"/>
                            <MenuItem Header="复制品牌" Command="{Binding CopyBrandCommand}"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="删除" Command="{Binding DeleteGameCommand}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                            Foreground="#E53935"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <!-- Column Definitions -->
                <DataGrid.Columns>
                    <!-- Status (icon only) -->
                    <DataGridTemplateColumn Header="" Width="32" CanUserResize="False"
                                             SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <iconPacks:PackIconMaterial
                                    Kind="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                    Width="14" Height="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Title -->
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}"
                                         Width="*" MinWidth="120"
                                         ElementStyle="{StaticResource {x:Type TextBlock}}"
                                         Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>

                    <!-- Brand -->
                    <DataGridTextColumn Header="Brand" Binding="{Binding Brand}"
                                         Width="120"
                                         Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>

                    <!-- Release Date -->
                    <DataGridTextColumn Header="Release Date"
                                         Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}"
                                         Width="95"
                                         Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>

                    <!-- Playtime -->
                    <DataGridTextColumn Header="Playtime"
                                         Binding="{Binding Playtime, Converter={StaticResource PlaytimeConverter}}"
                                         Width="75"
                                         Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>

                    <!-- Created Date -->
                    <DataGridTextColumn Header="Created"
                                         Binding="{Binding CreatedDate, StringFormat=yyyy-MM-dd}"
                                         Width="85"
                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>

                    <!-- Accessed Date -->
                    <DataGridTextColumn Header="Last Played"
                                         Binding="{Binding AccessedDate, StringFormat=yyyy-MM-dd}"
                                         Width="85"
                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </DataGrid.Columns>

            </DataGrid>
        </Grid>

    </DockPanel>
</mah:MetroWindow>
