<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:Perelegans.Converters"
        xmlns:models="clr-namespace:Perelegans.Models"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        mc:Ignorable="d"
        Title="Perelegans"
        TitleCharacterCasing="Normal"
        Height="680" Width="1100"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        ShowTitleBar="False"
        ShowCloseButton="False"
        ShowMinButton="False"
        ShowMaxRestoreButton="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Perelegans.WindowBackground}"
        mah:DialogParticipation.Register="{Binding}">

    <mah:MetroWindow.Resources>
        <converters:PlaytimeConverter x:Key="PlaytimeConverter"/>
        <converters:StatusIconConverter x:Key="StatusIconConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="SelectedPrimaryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlaytimeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.PlaytimeForegroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- ==================== 1. CUSTOM TITLE BAR ==================== -->
        <Grid DockPanel.Dock="Top" Height="30"
              Background="{DynamicResource Perelegans.PanelBackground}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <iconPacks:PackIconMaterial Kind="GamepadVariantOutline"
                                            Width="14" Height="14"
                                            Foreground="{DynamicResource Perelegans.AccentBrush}"
                                            VerticalAlignment="Center"/>
                <TextBlock Text="Perelegans" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                           Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: Settings / Min / Max / Close buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Stretch">
                <!-- Settings -->
                <Button x:Name="BtnSettings" Click="BtnSettings_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Settings">
                    <iconPacks:PackIconMaterial Kind="CogOutline" Width="12" Height="12"/>
                </Button>
                <!-- Minimize -->
                <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Minimize">
                    <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="12" Height="12"/>
                </Button>
                <!-- Maximize / Restore -->
                <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Maximize">
                    <iconPacks:PackIconMaterial Kind="WindowMaximize" Width="12" Height="12"
                                                x:Name="MaximizeIcon"/>
                </Button>
                <!-- Close -->
                <Button x:Name="BtnClose" Click="BtnClose_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.CloseButtonStyle}"
                        ToolTip="Close">
                    <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== 2. MENU BAR ==================== -->
        <Menu DockPanel.Dock="Top" Height="28"
              Background="{DynamicResource Perelegans.PanelBackground}"
              Foreground="{DynamicResource Perelegans.ForegroundBrush}"
              FontSize="12" Padding="4,0">

            <!-- File -->
            <MenuItem Header="{i18n:Translate Menu_File}">
                <MenuItem Header="{i18n:Translate Menu_AddFromProcess}" Command="{Binding AddFromProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ApplicationCogOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_AddFromWebsite}" Command="{Binding AddFromWebsiteCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Web" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_SaveBackup}" Command="{Binding SaveBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_RestoreBackup}" Command="{Binding RestoreBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Restore" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_Exit}" Command="{Binding ExitAppCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Tool -->
            <MenuItem Header="{i18n:Translate Menu_Tool}">
                <MenuItem Header="{i18n:Translate Menu_MonitorProcess}" Command="{Binding MonitorProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Check" Width="14" Height="14"
                            Visibility="{Binding IsMonitorEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_PlaytimeStats}" Command="{Binding PlaytimeStatisticsCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="{i18n:Translate Menu_Help}">
                <MenuItem Header="{i18n:Translate Menu_About}" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ==================== 4. STATUS BAR ==================== -->
        <StatusBar DockPanel.Dock="Bottom" Height="22"
                   Background="{DynamicResource Perelegans.StatusBarBackground}"
                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                   FontSize="11" Padding="8,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{i18n:Translate Status_TotalPlaytime}"/>
                        <Run Text="{Binding TotalPlaytimeText, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.StatusBarValueForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{i18n:Translate Status_Completed}"/>
                        <Run Text="{Binding CompletedCount, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.StatusBarValueForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== 3. CLIENT AREA ==================== -->
        <Grid Background="{DynamicResource Perelegans.WindowBackground}">

            <!-- Background Tachie Image (lower z-index) -->
            <Image Source="pack://application:,,,/Images/sho02A_101.png"
                   Stretch="Uniform"
                   Opacity="0.12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   MaxHeight="500"
                   MaxWidth="350"
                   Margin="0,0,10,10"
                   Panel.ZIndex="0"
                   IsHitTestVisible="False"/>

            <!-- DataGrid (upper z-index) -->
            <DataGrid x:Name="GameDataGrid"
                      ItemsSource="{Binding Games}"
                      SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="24"
                      ColumnHeaderHeight="26"
                      FontSize="12"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="Transparent"
                      Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                      HorizontalGridLinesBrush="{DynamicResource Perelegans.BorderBrush}"
                      Panel.ZIndex="1"
                      Margin="0">

                <!-- Context Menu -->
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{i18n:Translate Context_StartGame}" Command="{Binding StartGameCommand}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{i18n:Translate Context_Metadata}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="DatabaseOutline" Width="14" Height="14"/>
                            </MenuItem.Icon>
                            <MenuItem Header="{i18n:Translate Context_FetchMetadata}" Command="{Binding FetchMetadataCommand}"/>
                            <MenuItem Header="{i18n:Translate Context_EditMetadata}" Command="{Binding EditMetadataCommand}"/>
                        </MenuItem>
                        <MenuItem Header="{i18n:Translate Context_Open}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Width="14" Height="14"/>
                            </MenuItem.Icon>
                            <MenuItem Header="{i18n:Translate Context_OpenFolder}" Command="{Binding OpenGameFolderCommand}"/>
                            <MenuItem Header="{i18n:Translate Context_OpenWebsite}">
                                <MenuItem Header="VNDB" Command="{Binding OpenVndbCommand}"/>
                                <MenuItem Header="ErogameSpace" Command="{Binding OpenErogameSpaceCommand}"/>
                                <MenuItem Header="Bangumi" Command="{Binding OpenBangumiCommand}"/>
                                <MenuItem Header="Official Site" Command="{Binding OpenOfficialSiteCommand}"/>
                            </MenuItem>
                            <MenuItem Header="{i18n:Translate Context_OpenGameStats}" Command="{Binding OpenGamePlaytimeStatsCommand}"/>
                        </MenuItem>
                        <MenuItem Header="{i18n:Translate Context_Copy}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                            </MenuItem.Icon>
                            <MenuItem Header="{i18n:Translate Context_CopyTitle}" Command="{Binding CopyTitleCommand}"/>
                            <MenuItem Header="{i18n:Translate Context_CopyBrand}" Command="{Binding CopyBrandCommand}"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="{i18n:Translate Context_Delete}" Command="{Binding DeleteGameCommand}">
                            <MenuItem.Icon>
                                <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                            Foreground="#E53935"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <!-- Column Definitions -->
                <DataGrid.Columns>
                    <!-- Status (icon only) -->
                    <DataGridTemplateColumn Header="" Width="32" CanUserResize="False"
                                             SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <iconPacks:PackIconMaterial
                                    Kind="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                    Width="14" Height="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource Perelegans.StatusIconBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Title -->
                    <DataGridTextColumn Header="{i18n:Translate Column_Title}" Binding="{Binding Title}"
                                         Width="*" MinWidth="120"
                                         ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                    <!-- Brand -->
                    <DataGridTextColumn Header="{i18n:Translate Column_Brand}" Binding="{Binding Brand}"
                                         Width="120"
                                         ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                    <!-- Release Date -->
                    <DataGridTextColumn Header="{i18n:Translate Column_ReleaseDate}"
                                         Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}"
                                         Width="95"
                                         ElementStyle="{StaticResource SelectedPrimaryTextStyle}"/>

                    <!-- Playtime -->
                    <DataGridTextColumn Header="{i18n:Translate Column_Playtime}"
                                         Binding="{Binding Playtime, Converter={StaticResource PlaytimeConverter}}"
                                         Width="75"
                                         ElementStyle="{StaticResource PlaytimeTextStyle}"/>

                    <!-- Created Date -->
                    <DataGridTextColumn Header="{i18n:Translate Column_Created}"
                                         Binding="{Binding CreatedDate, StringFormat=yyyy-MM-dd}"
                                         Width="85"
                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>

                    <!-- Accessed Date -->
                    <DataGridTextColumn Header="{i18n:Translate Column_LastPlayed}"
                                         Binding="{Binding AccessedDate, StringFormat=yyyy-MM-dd}"
                                         Width="85"
                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </DataGrid.Columns>

            </DataGrid>
        </Grid>

    </DockPanel>
</mah:MetroWindow>
