<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:Perelegans.Converters"
        xmlns:controls="clr-namespace:Perelegans.Controls"
        xmlns:models="clr-namespace:Perelegans.Models"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        xmlns:services="clr-namespace:Perelegans.Services"
        mc:Ignorable="d"
        Title="Perelegans"
        TitleCharacterCasing="Normal"
        Height="680" Width="1100"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        ShowTitleBar="False"
        ShowCloseButton="False"
        ShowMinButton="False"
        ShowMaxRestoreButton="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Perelegans.WindowBackground}"
        mah:DialogParticipation.Register="{Binding}">

    <mah:MetroWindow.Resources>
        <converters:PlaytimeConverter x:Key="PlaytimeConverter"/>
        <converters:CoverAspectRatioToHeightConverter x:Key="CoverAspectRatioToHeightConverter"/>
        <converters:CoverArtImageSourceConverter x:Key="CoverArtImageSourceConverter"/>
        <converters:CoverAspectRatioToStretchConverter x:Key="CoverAspectRatioToStretchConverter"/>
        <converters:StatusIconConverter x:Key="StatusIconConverter"/>
        <converters:LocalizedStringFormatConverter x:Key="LocalizedStringFormatConverter"/>
        <converters:AssistantMessageBrushConverter x:Key="AssistantMessageBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="ShellSidebarBackgroundBrush" Color="#202126"/>
        <SolidColorBrush x:Key="ShellHeaderBackgroundBrush" Color="#25272E"/>
        <SolidColorBrush x:Key="ShellNavigationHoverBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="ShellNavigationActiveBrush" Color="#30FFC0CB"/>
        <SolidColorBrush x:Key="ShellNavigationActiveRailBrush" Color="#FFC0CB"/>
        <SolidColorBrush x:Key="ShellNavigationForegroundBrush" Color="#B8BEC8"/>
        <SolidColorBrush x:Key="ShellNavigationActiveForegroundBrush" Color="#F7F9FC"/>
        <SolidColorBrush x:Key="ShellPrimaryActionBrush" Color="#FFC0CB"/>
        <SolidColorBrush x:Key="ShellPrimaryActionHoverBrush" Color="#FFD2DA"/>
        <SolidColorBrush x:Key="ShellPrimaryActionPressedBrush" Color="#EAA8B4"/>
        <Style x:Key="ShellNavigationButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{StaticResource ShellNavigationForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="ActiveRail"
                                        Width="2"
                                        Margin="0,8,0,8"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource ShellNavigationActiveRailBrush}"
                                        CornerRadius="0"
                                        Opacity="0"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ShellNavigationHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource ShellNavigationActiveForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ShellNavigationActiveBrush}"/>
                                <Setter TargetName="ActiveRail" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="{StaticResource ShellNavigationActiveForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ShellAssistantNavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellNavigationButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAssistantPanelVisible}" Value="True">
                    <Setter Property="Tag" Value="Active"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShellLibraryNavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellNavigationButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAssistantPanelVisible}" Value="False">
                    <Setter Property="Tag" Value="Active"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShellPrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="94"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource ShellPrimaryActionBrush}"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ShellPrimaryActionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ShellPrimaryActionPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="CardMetaTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="GameCardListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="GameCard_PreviewMouseRightButtonDown"/>
            <EventSetter Event="MouseDoubleClick" Handler="GameCard_MouseDoubleClick"/>
        </Style>
        <Style x:Key="CardRowListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

                <Grid DockPanel.Dock="Top" Height="30"
              Background="{DynamicResource Perelegans.PanelBackground}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <iconPacks:PackIconMaterial Kind="GamepadVariantOutline"
                                            Width="14" Height="14"
                                            Foreground="{DynamicResource Perelegans.AccentBrush}"
                                            VerticalAlignment="Center"/>
                <TextBlock Text="Perelegans" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                           Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Stretch">
                <Button x:Name="BtnGameManagement"
                        Click="BtnGameManagement_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="{i18n:Translate Toolbar_ManageGames}">
                    <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="12" Height="12"/>
                </Button>
                <Button x:Name="BtnSettings" Click="BtnSettings_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="{i18n:Translate TitleBar_Settings}">
                    <iconPacks:PackIconMaterial Kind="CogOutline" Width="12" Height="12"/>
                </Button>
                <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="{i18n:Translate TitleBar_Minimize}">
                    <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="12" Height="12"/>
                </Button>
                <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="{i18n:Translate TitleBar_Maximize}">
                    <iconPacks:PackIconMaterial Kind="WindowMaximize" Width="12" Height="12"
                                                x:Name="MaximizeIcon"/>
                </Button>
                <Button x:Name="BtnClose" Click="BtnClose_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.CloseButtonStyle}"
                        ToolTip="{i18n:Translate TitleBar_Close}">
                    <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <Menu DockPanel.Dock="Top" Height="28"
              Background="{DynamicResource Perelegans.PanelBackground}"
              Foreground="{DynamicResource Perelegans.ForegroundBrush}"
              FontSize="12" Padding="4,0">
            <MenuItem Header="{i18n:Translate Menu_File}">
                <MenuItem Header="{i18n:Translate Menu_AddFromProcess}" Command="{Binding AddFromProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ApplicationCogOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_AddFromWebsite}" Command="{Binding AddFromWebsiteCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Web" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_SaveBackup}" Command="{Binding SaveBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_RestoreBackup}" Command="{Binding RestoreBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Restore" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_Exit}" Command="{Binding ExitAppCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{i18n:Translate Menu_Tool}">
                <MenuItem Header="{i18n:Translate Menu_MonitorProcess}" Command="{Binding MonitorProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Check" Width="14" Height="14"
                            Visibility="{Binding IsMonitorEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_PlaytimeStats}" Command="{Binding PlaytimeStatisticsCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_Recommendations}" Command="{Binding OpenRecommendationsCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="LightbulbOnOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{i18n:Translate Menu_Help}">
                <MenuItem Header="{i18n:Translate Menu_About}" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Height="22"
                   Background="{DynamicResource Perelegans.StatusBarBackground}"
                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                   FontSize="11" Padding="8,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{i18n:Translate Status_TotalPlaytime}"/>
                        <Run Text="{Binding TotalPlaytimeText, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.StatusBarValueForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{i18n:Translate Status_Completed}"/>
                        <Run Text="{Binding CompletedCount, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.StatusBarValueForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
        <Grid Background="{DynamicResource Perelegans.WindowBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ShellColumn" Width="184"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource ShellSidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12,14">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="LIBRARY"
                                   Margin="10,0,0,8"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        <Button Style="{StaticResource ShellLibraryNavigationButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Kind="ViewGridOutline"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{i18n:Translate Toolbar_Library}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ShellNavigationButtonStyle}"
                                Command="{Binding OpenRecommendationsCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Kind="LightbulbOnOutline"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{i18n:Translate Toolbar_Recommendations}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ShellNavigationButtonStyle}"
                                Command="{Binding PlaytimeStatisticsCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Kind="ChartBar"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{i18n:Translate Toolbar_Stats}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ShellAssistantNavigationButtonStyle}"
                                Command="{Binding OpenAiAssistantCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Kind="RobotOutline"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{i18n:Translate Toolbar_AiAssistant}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource ShellHeaderBackgroundBrush}"
                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="18,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{i18n:Translate Toolbar_Library}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                       Margin="0,2,0,0">
                                <Run Text="{Binding TotalGameCount, Mode=OneWay}"/>
                                <Run Text="{i18n:Translate Toolbar_LibraryCountSuffix}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button x:Name="AddGameToolbarButton"
                                Grid.Column="1"
                                Style="{StaticResource ShellPrimaryActionButtonStyle}"
                                Click="AddGameToolbarButton_Click"
                                VerticalAlignment="Center">
                            <Button.ContextMenu>
                                <ContextMenu Placement="Bottom"
                                             HorizontalOffset="0"
                                             VerticalOffset="4">
                                    <MenuItem Header="{i18n:Translate Menu_AddFromProcess}"
                                              Command="{Binding PlacementTarget.DataContext.AddFromProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="ApplicationCogOutline" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{i18n:Translate Menu_AddFromWebsite}"
                                              Command="{Binding PlacementTarget.DataContext.AddFromWebsiteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="Web" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Plus"
                                                            Width="14"
                                                            Height="14"
                                                            Margin="0,0,5,0"
                                                            VerticalAlignment="Center"/>
                                <TextBlock Text="{i18n:Translate Toolbar_AddGame}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
            <Image Source="pack://application:,,,/Images/sho02A_101.png"
                   Stretch="Uniform"
                   Opacity="0.12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   MaxHeight="500"
                   MaxWidth="350"
                   Margin="0,0,10,10"
                   Panel.ZIndex="0"
                   IsHitTestVisible="False"/>

            <ListBox x:Name="GameCards"
                     ItemsSource="{Binding VisibleRows}"
                     SizeChanged="GameCards_SizeChanged"
                     ScrollViewer.ScrollChanged="GameCards_ScrollChanged"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     HorizontalContentAlignment="Stretch"
                     VerticalContentAlignment="Stretch"
                     Panel.ZIndex="1"
                     Margin="10,12,10,14">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel IsItemsHost="True" Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <StaticResource ResourceKey="CardRowListBoxItemStyle"/>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ListBox ItemsSource="{Binding}"
                                 SelectedItem="{Binding DataContext.SelectedGame, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}, Mode=TwoWay}"
                                 SelectionMode="Single"
                                 PreviewMouseLeftButtonDown="GameCards_PreviewMouseLeftButtonDown"
                                 PreviewMouseWheel="CardRow_PreviewMouseWheel"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="False">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,8,0,0"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <StaticResource ResourceKey="GameCardListBoxItemStyle"/>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Game}">
                                    <Border x:Name="GameCardBorder"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                            Background="{DynamicResource Perelegans.CardBackgroundBrush}"
                                            BorderBrush="#22FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="0"
                                            Width="196"
                                            Margin="0"
                                            HorizontalAlignment="Left"
                                            SnapsToDevicePixels="True"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="GameCardScaleTransform"
                                                            ScaleX="1"
                                                            ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10"
                                                              ShadowDepth="3"
                                                              Opacity="0.12"
                                                              Color="{DynamicResource Perelegans.CardShadowColor}"/>
                                        </Border.Effect>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{i18n:Translate Context_StartGame}"
                                                          Command="{Binding PlacementTarget.Tag.StartGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{i18n:Translate Context_EditMetadata}"
                                                          Command="{Binding PlacementTarget.Tag.EditMetadataCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="DatabaseOutline" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{i18n:Translate Context_Open}">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem Header="{i18n:Translate Context_OpenFolder}"
                                                              Command="{Binding PlacementTarget.Tag.OpenGameFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="{i18n:Translate Context_OpenWebsite}">
                                                        <MenuItem Header="{i18n:Translate Context_OpenVndb}"
                                                                  Command="{Binding PlacementTarget.Tag.OpenVndbCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{i18n:Translate Context_OpenErogameSpace}"
                                                                  Command="{Binding PlacementTarget.Tag.OpenErogameSpaceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{i18n:Translate Context_OpenBangumi}"
                                                                  Command="{Binding PlacementTarget.Tag.OpenBangumiCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{i18n:Translate Context_OpenOfficialSite}"
                                                                  Command="{Binding PlacementTarget.Tag.OpenOfficialSiteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </MenuItem>
                                                    <MenuItem Header="{i18n:Translate Context_OpenGameStats}"
                                                              Command="{Binding PlacementTarget.Tag.OpenGamePlaytimeStatsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>
                                                <MenuItem Header="{i18n:Translate Context_Copy}">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem Header="{i18n:Translate Context_CopyTitle}"
                                                              Command="{Binding PlacementTarget.Tag.CopyTitleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="{i18n:Translate Context_CopyBrand}"
                                                              Command="{Binding PlacementTarget.Tag.CopyBrandCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="{i18n:Translate Context_Delete}"
                                                          Command="{Binding PlacementTarget.Tag.DeleteGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                                                    Foreground="#E53935"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Border CornerRadius="0">
                                            <Grid Height="278">
                                                <Grid.Clip>
                                                    <RectangleGeometry Rect="0,0,196,278" RadiusX="0" RadiusY="0"/>
                                                </Grid.Clip>

                                                <Image Source="{Binding CoverDisplaySource, Converter={StaticResource CoverArtImageSourceConverter}}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       Opacity="0.34"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="LowQuality"/>

                                                <Border Background="#18000000"/>

                                                <Image Source="{Binding CoverDisplaySource, Converter={StaticResource CoverArtImageSourceConverter}}"
                                                       Stretch="{Binding CoverAspectRatio, Converter={StaticResource CoverAspectRatioToStretchConverter}}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="LowQuality">
                                                    <Image.OpacityMask>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                            <GradientStop Color="#FFFFFFFF" Offset="0.16"/>
                                                            <GradientStop Color="#FFFFFFFF" Offset="0.80"/>
                                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Image.OpacityMask>
                                                </Image>

                                                <Border VerticalAlignment="Bottom"
                                                        Height="126">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0"/>
                                                            <GradientStop Color="#70000000" Offset="0.45"/>
                                                            <GradientStop Color="#E0000000" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <Button Width="26"
                                                        Height="26"
                                                        Margin="12"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Click="StatusBadge_Click"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}">
                                                    <Button.ContextMenu>
                                                        <ContextMenu Placement="Bottom"
                                                                     HorizontalOffset="-2"
                                                                     VerticalOffset="2">
                                                            <MenuItem Header="{i18n:Translate GameStatus_Planned}"
                                                                      Command="{Binding PlacementTarget.Tag.ChangeGameStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{x:Static models:GameStatus.Planned}">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{i18n:Translate GameStatus_Playing}"
                                                                      Command="{Binding PlacementTarget.Tag.ChangeGameStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{x:Static models:GameStatus.Playing}">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="PlayCircleOutline" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{i18n:Translate GameStatus_Completed}"
                                                                      Command="{Binding PlacementTarget.Tag.ChangeGameStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{x:Static models:GameStatus.Completed}">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <Border Background="{DynamicResource Perelegans.CoverStatusBadgeBackgroundBrush}"
                                                            CornerRadius="13"
                                                            SnapsToDevicePixels="True">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="5"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.18"
                                                                              Color="{DynamicResource Perelegans.CoverStatusBadgeShadowColor}"/>
                                                        </Border.Effect>
                                                        <iconPacks:PackIconMaterial Kind="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                                                                    Width="14"
                                                                                    Height="14"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Foreground="{DynamicResource Perelegans.StatusIconBrush}"/>
                                                    </Border>
                                                </Button>

                                                <StackPanel VerticalAlignment="Bottom"
                                                            HorizontalAlignment="Left"
                                                            Margin="12,0,12,14">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource CardTitleTextStyle}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="40"/>
                                                    <TextBlock Text="{Binding Brand}"
                                                               Style="{StaticResource CardMetaTextStyle}"
                                                               FontSize="10"
                                                               Margin="0,3,0,0"
                                                               Opacity="0.92"/>
                                                    <TextBlock Style="{StaticResource CardMetaTextStyle}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Margin="0,8,0,0">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource PlaytimeConverter}">
                                                                <Binding Path="Playtime"/>
                                                                <Binding Source="{x:Static services:TranslationService.Instance}"
                                                                         Path="[Playtime_HoursMinutes]"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource CardMetaTextStyle}"
                                                               FontSize="10"
                                                               Margin="0,4,0,0">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource LocalizedStringFormatConverter}">
                                                                <Binding Source="{x:Static services:TranslationService.Instance}"
                                                                         Path="[Card_LastPlayedFormat]"/>
                                                                <Binding Path="AccessedDate"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                            <Setter TargetName="GameCardBorder" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard FillBehavior="HoldEnd">
                                                        <DoubleAnimation Storyboard.TargetName="GameCardScaleTransform"
                                                                         Storyboard.TargetProperty="ScaleX"
                                                                         To="1.01"
                                                                         Duration="0:0:0.11">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="GameCardScaleTransform"
                                                                         Storyboard.TargetProperty="ScaleY"
                                                                         To="1.01"
                                                                         Duration="0:0:0.11">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard FillBehavior="HoldEnd">
                                                        <DoubleAnimation Storyboard.TargetName="GameCardScaleTransform"
                                                                         Storyboard.TargetProperty="ScaleX"
                                                                         To="1"
                                                                         Duration="0:0:0.10">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="GameCardScaleTransform"
                                                                         Storyboard.TargetProperty="ScaleY"
                                                                         To="1"
                                                                         Duration="0:0:0.10">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter TargetName="GameCardBorder" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDetectedRunning}" Value="True">
                                            <Setter TargetName="GameCardBorder" Property="BorderBrush" Value="#FFBFCA"/>
                                            <Setter TargetName="GameCardBorder" Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
                </Grid>
            </Grid>

            <Border Grid.Column="0"
                    Margin="0,0,0,0"
                    Padding="12"
                    Background="{DynamicResource Perelegans.PanelBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsAssistantPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid DataContext="{Binding AssistantViewModel}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{i18n:Translate Assistant_Title}"
                                       FontSize="17"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{i18n:Translate Assistant_Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Command="{Binding DataContext.CloseAssistantPanelCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                Style="{DynamicResource MahApps.Styles.Button.Square}">
                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </Grid>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding QuickQuestions}"
                                  Margin="0,0,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Margin="0,0,6,6"
                                        Padding="8,4"
                                        FontSize="11"
                                        Command="{Binding DataContext.AskQuickQuestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Background="{DynamicResource Perelegans.WindowBackground}"
                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="10"
                                                    Background="{Binding IsUser, Converter={StaticResource AssistantMessageBrushConverter}}"
                                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Role}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Opacity="0.68"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding Content}"
                                                               TextWrapping="Wrap"
                                                               LineHeight="19"/>
                                                    <ItemsControl ItemsSource="{Binding GameLinks}"
                                                                  Visibility="{Binding HasGameLinks, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                  Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,6">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button Grid.Column="0"
                                                                            HorizontalContentAlignment="Left"
                                                                            Padding="8,5"
                                                                            Command="{Binding DataContext.AssistantViewModel.SelectGameCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{DynamicResource MahApps.Styles.Button.Square}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"/>
                                                                            <TextBlock Text="{Binding Subtitle}"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       FontSize="10"
                                                                                       Opacity="0.7"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Grid.Column="1"
                                                                            Width="30"
                                                                            Margin="4,0,0,0"
                                                                            Padding="0"
                                                                            Command="{Binding DataContext.AssistantViewModel.OpenGameMetadataCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{DynamicResource MahApps.Styles.Button.Square}">
                                                                        <iconPacks:PackIconMaterial Kind="PencilOutline" Width="14" Height="14"/>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Button Content="{Binding ActionLabel}"
                                                            Margin="0,4,0,0"
                                                            HorizontalAlignment="Left"
                                                            Padding="8,4"
                                                            Visibility="{Binding HasAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Command="{Binding DataContext.AssistantViewModel.RunMessageActionCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                                                    <TextBlock Text="{Binding SourceSummary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,8,0,0"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                               Visibility="{Binding HasSourceSummary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding DebugSummary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,3,0,0"
                                                               FontSize="10"
                                                               Opacity="0.55"
                                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                               Visibility="{Binding HasDebugSummary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border VerticalAlignment="Bottom"
                                    HorizontalAlignment="Left"
                                    Margin="10"
                                    Padding="10,7"
                                    CornerRadius="4"
                                    Background="{DynamicResource Perelegans.CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding HasBusyStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <ProgressBar Width="42"
                                                 Height="4"
                                                 IsIndeterminate="True"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding BusyStatusText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,10,0,0"
                            Padding="8"
                            Background="{DynamicResource Perelegans.WindowBackground}"
                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     MinHeight="54"
                                     MaxHeight="96"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     PreviewKeyDown="AssistantInput_PreviewKeyDown"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1"
                                    Width="62"
                                    Margin="6,0,0,0"
                                    Content="{i18n:Translate Assistant_Send}"
                                    Command="{Binding SendCommand}"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                            <Button Grid.Column="2"
                                    Width="32"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    Command="{Binding CancelCommand}"
                                    Style="{DynamicResource MahApps.Styles.Button.Square}">
                                <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </DockPanel>
</mah:MetroWindow>












