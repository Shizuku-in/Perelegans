<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:Perelegans.Converters"
        xmlns:controls="clr-namespace:Perelegans.Controls"
        xmlns:models="clr-namespace:Perelegans.Models"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        mc:Ignorable="d"
        Title="Perelegans"
        TitleCharacterCasing="Normal"
        Height="680" Width="1100"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        ShowTitleBar="False"
        ShowCloseButton="False"
        ShowMinButton="False"
        ShowMaxRestoreButton="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Perelegans.WindowBackground}"
        mah:DialogParticipation.Register="{Binding}">

    <mah:MetroWindow.Resources>
        <converters:PlaytimeConverter x:Key="PlaytimeConverter"/>
        <converters:StatusIconConverter x:Key="StatusIconConverter"/>
        <converters:BulkDeleteSelectionModeConverter x:Key="BulkDeleteSelectionModeConverter"/>
        <converters:CoverAspectRatioToStretchConverter x:Key="CoverAspectRatioToStretchConverter"/>
        <converters:CoverAspectRatioToHeightConverter x:Key="CoverAspectRatioToHeightConverter"/>
        <converters:CoverArtImageSourceConverter x:Key="CoverArtImageSourceConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="SelectedPrimaryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RunningTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDetectedRunning}" Value="True">
                    <Setter Property="Foreground" Value="#E37F7F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsDetectedRunning}" Value="True"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="#E37F7F"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlaytimeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.PlaytimeForegroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Perelegans.DataGridSelectedPrimaryForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BulkSelectableListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="210"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardRoot"
                                Background="{DynamicResource Perelegans.PanelBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource Perelegans.MenuHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="GameCard_PreviewMouseRightButtonDown"/>
            <EventSetter Event="MouseDoubleClick" Handler="GameCard_MouseDoubleClick"/>
        </Style>
        <Style x:Key="CardTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="CardMetaTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="VisibleWhenBulkDeleteModeStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBulkDeleteMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNotBulkDeleteModeStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBulkDeleteMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- ==================== 1. CUSTOM TITLE BAR ==================== -->
        <Grid DockPanel.Dock="Top" Height="30"
              Background="{DynamicResource Perelegans.PanelBackground}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <iconPacks:PackIconMaterial Kind="GamepadVariantOutline"
                                            Width="14" Height="14"
                                            Foreground="{DynamicResource Perelegans.AccentBrush}"
                                            VerticalAlignment="Center"/>
                <TextBlock Text="Perelegans" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                           Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: Settings / Min / Max / Close buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Stretch">
                <!-- Settings -->
                <Button x:Name="BtnSettings" Click="BtnSettings_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Settings">
                    <iconPacks:PackIconMaterial Kind="CogOutline" Width="12" Height="12"/>
                </Button>
                <!-- Minimize -->
                <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Minimize">
                    <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="12" Height="12"/>
                </Button>
                <!-- Maximize / Restore -->
                <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.TitleBarButtonStyle}"
                        ToolTip="Maximize">
                    <iconPacks:PackIconMaterial Kind="WindowMaximize" Width="12" Height="12"
                                                x:Name="MaximizeIcon"/>
                </Button>
                <!-- Close -->
                <Button x:Name="BtnClose" Click="BtnClose_Click"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource Perelegans.CloseButtonStyle}"
                        ToolTip="Close">
                    <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== 2. MENU BAR ==================== -->
        <Menu DockPanel.Dock="Top" Height="28"
              Background="{DynamicResource Perelegans.PanelBackground}"
              Foreground="{DynamicResource Perelegans.ForegroundBrush}"
              FontSize="12" Padding="4,0">

            <!-- File -->
            <MenuItem Header="{i18n:Translate Menu_File}">
                <MenuItem Header="{i18n:Translate Menu_AddFromProcess}" Command="{Binding AddFromProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ApplicationCogOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_AddFromWebsite}" Command="{Binding AddFromWebsiteCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Web" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_SaveBackup}" Command="{Binding SaveBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_RestoreBackup}" Command="{Binding RestoreBackupCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Restore" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_Exit}" Command="{Binding ExitAppCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Tool -->
            <MenuItem Header="{i18n:Translate Menu_Tool}">
                <MenuItem Header="{i18n:Translate Menu_MonitorProcess}" Command="{Binding MonitorProcessCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Check" Width="14" Height="14"
                            Visibility="{Binding IsMonitorEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_PlaytimeStats}" Command="{Binding PlaytimeStatisticsCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{i18n:Translate Menu_Recommendations}" Command="{Binding OpenRecommendationsCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="LightbulbOnOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{i18n:Translate Menu_BatchMetadata}" Command="{Binding OpenBatchMetadataCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="DatabaseEdit" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="{i18n:Translate Menu_Help}">
                <MenuItem Header="{i18n:Translate Menu_About}" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ==================== 4. STATUS BAR ==================== -->
        <StatusBar DockPanel.Dock="Bottom" Height="22"
                   Background="{DynamicResource Perelegans.StatusBarBackground}"
                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                   FontSize="11" Padding="8,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ClockOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{i18n:Translate Status_TotalPlaytime}"/>
                        <Run Text="{Binding TotalPlaytimeText, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.StatusBarValueForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="11" Height="11"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{i18n:Translate Status_Completed}"/>
                        <Run Text="{Binding CompletedCount, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource Perelegans.StatusBarValueForegroundBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== 3. CLIENT AREA ==================== -->
        <Grid Background="{DynamicResource Perelegans.WindowBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Background Tachie Image -->
            <Image Source="pack://application:,,,/Images/sho02A_101.png"
                   Grid.RowSpan="2"
                   Stretch="Uniform"
                   Opacity="0.12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   MaxHeight="500"
                   MaxWidth="350"
                   Margin="0,0,10,10"
                   Panel.ZIndex="0"
                   IsHitTestVisible="False"/>

            <Grid Grid.Row="0" Margin="8,4">
                <Button HorizontalAlignment="Right"
                        Height="26"
                        FontSize="12"
                        Padding="10,0"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Command="{Binding ToggleBulkDeleteModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBulkDeleteMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                    Foreground="#E53935" Margin="0,0,4,0"/>
                        <TextBlock Text="{i18n:Translate Context_Delete}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            <!-- Batch Operation Toolbar -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Style="{StaticResource VisibleWhenBulkDeleteModeStyle}">
                <Button Height="26" FontSize="12" Margin="0,0,6,0"
                        Padding="10,0"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Command="{Binding ToggleBulkDeleteModeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14"
                                                    Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                    Margin="0,0,4,0"/>
                        <TextBlock Text="{i18n:Translate Btn_Cancel}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Height="26" FontSize="12" Margin="0,0,6,0"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Content="{i18n:Translate GameMgmt_SelectAll}"
                        Command="{Binding SelectAllGamesCommand}"/>
                <Button Height="26" FontSize="12" Margin="0,0,6,0"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Content="{i18n:Translate GameMgmt_DeselectAll}"
                        Command="{Binding DeselectAllGamesCommand}"/>
                <Button Height="26" FontSize="12"
                        BorderBrush="{DynamicResource Perelegans.ButtonBorderBrush}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Command="{Binding DeleteSelectedGamesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                    Foreground="#E53935" Margin="0,0,4,0"/>
                        <TextBlock Text="{i18n:Translate GameMgmt_DeleteSelected}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            </Grid>

            <!-- Card Gallery -->
            <ListBox x:Name="GameCards"
                     Grid.Row="1"
                     ItemsSource="{Binding Games}"
                     SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                     SelectionMode="{Binding IsBulkDeleteMode, Converter={StaticResource BulkDeleteSelectionModeConverter}}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False"
                     HorizontalContentAlignment="Stretch"
                     VerticalContentAlignment="Stretch"
                     Panel.ZIndex="1"
                     Margin="12,4,12,12">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:MasonryPanel IsItemsHost="True"
                                               ColumnWidth="210"
                                               ItemSpacing="14"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <StaticResource ResourceKey="BulkSelectableListBoxItemStyle"/>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Game}">
                        <Border Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{i18n:Translate Context_StartGame}"
                                              Command="{Binding PlacementTarget.Tag.StartGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{i18n:Translate Context_Metadata}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="DatabaseOutline" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="{i18n:Translate Context_FetchMetadata}"
                                                  Command="{Binding PlacementTarget.Tag.FetchMetadataCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="{i18n:Translate Context_EditMetadata}"
                                                  Command="{Binding PlacementTarget.Tag.EditMetadataCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </MenuItem>
                                    <MenuItem Header="{i18n:Translate Context_Open}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="{i18n:Translate Context_OpenFolder}"
                                                  Command="{Binding PlacementTarget.Tag.OpenGameFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="{i18n:Translate Context_OpenWebsite}">
                                            <MenuItem Header="VNDB"
                                                      Command="{Binding PlacementTarget.Tag.OpenVndbCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="ErogameSpace"
                                                      Command="{Binding PlacementTarget.Tag.OpenErogameSpaceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Bangumi"
                                                      Command="{Binding PlacementTarget.Tag.OpenBangumiCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Official Site"
                                                      Command="{Binding PlacementTarget.Tag.OpenOfficialSiteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </MenuItem>
                                        <MenuItem Header="{i18n:Translate Context_OpenGameStats}"
                                                  Command="{Binding PlacementTarget.Tag.OpenGamePlaytimeStatsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </MenuItem>
                                    <MenuItem Header="{i18n:Translate Context_Copy}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="{i18n:Translate Context_CopyTitle}"
                                                  Command="{Binding PlacementTarget.Tag.CopyTitleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="{i18n:Translate Context_CopyBrand}"
                                                  Command="{Binding PlacementTarget.Tag.CopyBrandCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{i18n:Translate Context_Delete}"
                                              Command="{Binding PlacementTarget.Tag.DeleteGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14"
                                                                        Foreground="#E53935"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Grid Width="210" ClipToBounds="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.Height>
                                        <MultiBinding Converter="{StaticResource CoverAspectRatioToHeightConverter}">
                                            <Binding RelativeSource="{RelativeSource Self}" Path="ActualWidth"/>
                                            <Binding Path="CoverAspectRatio"/>
                                        </MultiBinding>
                                    </Grid.Height>

                                    <Image Source="{Binding CoverDisplaySource, Converter={StaticResource CoverArtImageSourceConverter}}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Opacity="0.22"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <BlurEffect Radius="18"/>
                                        </Image.Effect>
                                    </Image>

                                    <Image Source="{Binding CoverDisplaySource, Converter={StaticResource CoverArtImageSourceConverter}}"
                                           Stretch="{Binding CoverAspectRatio, Converter={StaticResource CoverAspectRatioToStretchConverter}}"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="Linear"/>

                                    <Border VerticalAlignment="Bottom" Height="96">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0"/>
                                                <GradientStop Color="#33000000" Offset="0.35"/>
                                                <GradientStop Color="#AA000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="10"
                                            Padding="6,2"
                                            CornerRadius="10"
                                            Background="#CCFFFFFF">
                                        <iconPacks:PackIconMaterial Kind="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                                                    Width="10"
                                                                    Height="10"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{DynamicResource Perelegans.StatusIconBrush}"/>
                                    </Border>

                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="10"
                                            Padding="6,2"
                                            CornerRadius="10"
                                            Background="#CCF48FB1"
                                            Visibility="{Binding IsDetectedRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Running"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="1" Margin="12,12,12,14">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource RunningTitleTextStyle}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               MaxHeight="42"/>
                                    <TextBlock Text="{Binding Brand}"
                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                               FontSize="10.5"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               MaxHeight="32"/>
                                    <TextBlock Text="{Binding Playtime, Converter={StaticResource PlaytimeConverter}}"
                                               Style="{StaticResource PlaytimeTextStyle}"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding AccessedDate, StringFormat=Last played {0:yyyy-MM-dd}}"
                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                               FontSize="10.5"
                                               Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding CreatedDate, StringFormat=Added {0:yyyy-MM-dd}}"
                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                               FontSize="10.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </DockPanel>
</mah:MetroWindow>
