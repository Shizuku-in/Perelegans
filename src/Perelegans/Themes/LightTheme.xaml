<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Perelegans Light Theme: Off-white (米白) + Pink -->

    <!-- Window & Panel Backgrounds -->
    <SolidColorBrush x:Key="Perelegans.WindowBackground" Color="#FDFCF8"/>
    <SolidColorBrush x:Key="Perelegans.PanelBackground" Color="#F5F3EE"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBackground" Color="#FDFCF8"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBorderBrush" Color="#D8D1C6"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartMetricBackground" Color="#EFECE5"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartSliceBorderBrush" Color="#F3EFE8"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBackground" Color="#FFF0F0"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBorderBrush" Color="#E37F7F"/>
    
    <!-- Accent -->
    <Color x:Key="Perelegans.AccentColor">#FFC0CB</Color>
    <SolidColorBrush x:Key="Perelegans.AccentBrush" Color="#FFC0CB"/>
    <SolidColorBrush x:Key="Perelegans.AccentHoverBrush" Color="#FFC0CB"/>
    <SolidColorBrush x:Key="MahApps.Brushes.Accent" Color="#FFC0CB"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="Perelegans.ForegroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Perelegans.SubtleForegroundBrush" Color="#757575"/>
    <SolidColorBrush x:Key="Perelegans.PlaytimeForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="Perelegans.StatusBarValueForegroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedPrimaryForegroundBrush" Color="#5D1135"/>
    <SolidColorBrush x:Key="Perelegans.StatusIconBrush" Color="#FFD2DB"/>
    <SolidColorBrush x:Key="Perelegans.CoverStatusBadgeBackgroundBrush" Color="#FDFCF8"/>
    <Color x:Key="Perelegans.CoverStatusBadgeShadowColor">#2d2d30</Color>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Perelegans.BorderBrush" Color="#E0DDD5"/>
    <SolidColorBrush x:Key="Perelegans.ButtonBorderBrush" Color="#FFFFFF"/>
    
    <!-- DataGrid -->
    <SolidColorBrush x:Key="Perelegans.DataGridAltRowBrush" Color="#F8F6F1"/>
    <SolidColorBrush x:Key="Perelegans.DataGridHeaderBackground" Color="#EFECE5"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedRowBrush" Color="#FFE6ED"/>
    
    <!-- StatusBar -->
    <SolidColorBrush x:Key="Perelegans.StatusBarBackground" Color="#EFECE5"/>
    
    <!-- Menu -->
    <SolidColorBrush x:Key="Perelegans.MenuBackground" Color="#FDFCF8"/>
    <SolidColorBrush x:Key="Perelegans.MenuHoverBrush" Color="#FCE4EC"/>

</ResourceDictionary>
