<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Perelegans Dark Theme: Dark Gray + Pink (desaturated) -->

    <!-- Window & Panel Backgrounds -->
    <SolidColorBrush x:Key="Perelegans.WindowBackground" Color="#252526"/>
    <SolidColorBrush x:Key="Perelegans.PanelBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBackground" Color="#252526"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBorderBrush" Color="#3A3A3C"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartMetricBackground" Color="#303033"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartSliceBorderBrush" Color="#252526"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBackground" Color="#3A2E31"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBorderBrush" Color="#E37F7F"/>
    
    <!-- Accent (slightly desaturated pink for dark-mode contrast) -->
    <Color x:Key="Perelegans.AccentColor">#FFC0CB</Color>
    <SolidColorBrush x:Key="Perelegans.AccentBrush" Color="#FFC0CB"/>
    <SolidColorBrush x:Key="Perelegans.AccentHoverBrush" Color="#FFC0CB"/>
    <SolidColorBrush x:Key="MahApps.Brushes.Accent" Color="#FFC0CB"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="Perelegans.ForegroundBrush" Color="#DCDCDC"/>
    <SolidColorBrush x:Key="Perelegans.SubtleForegroundBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="Perelegans.PlaytimeForegroundBrush" Color="#DCDCDC"/>
    <SolidColorBrush x:Key="Perelegans.StatusBarValueForegroundBrush" Color="#C8C8C8"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedPrimaryForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="Perelegans.StatusIconBrush" Color="#FFD2DB"/>
    <SolidColorBrush x:Key="Perelegans.CoverStatusBadgeBackgroundBrush" Color="#2d2d30"/>
    <Color x:Key="Perelegans.CoverStatusBadgeShadowColor">#FDFCF8</Color>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Perelegans.BorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="Perelegans.ButtonBorderBrush" Color="#3F3F46"/>
    
    <!-- DataGrid -->
    <SolidColorBrush x:Key="Perelegans.DataGridAltRowBrush" Color="#2A2A2E"/>
    <SolidColorBrush x:Key="Perelegans.DataGridHeaderBackground" Color="#333337"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedRowBrush" Color="#FFE6ED"/>
    
    <!-- StatusBar -->
    <SolidColorBrush x:Key="Perelegans.StatusBarBackground" Color="#1E1E1E"/>
    
    <!-- Menu -->
    <SolidColorBrush x:Key="Perelegans.MenuBackground" Color="#252526"/>
    <SolidColorBrush x:Key="Perelegans.MenuHoverBrush" Color="#3E3E42"/>

</ResourceDictionary>
